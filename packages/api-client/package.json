{
  "name": "@repo/api-client",
  "version": "1.0.0",
  "private": true,
  "description": "API client for BFF communication - used by storefront and dashboard",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./products": {
      "types": "./dist/products.d.ts",
      "default": "./dist/products.js"
    },
    "./categories": {
      "types": "./dist/categories.d.ts",
      "default": "./dist/categories.js"
    },
    "./checkout": {
      "types": "./dist/checkout.d.ts",
      "default": "./dist/checkout.js"
    },
    "./payments": {
      "types": "./dist/payments.d.ts",
      "default": "./dist/payments.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@repo/config": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
