# API Server Port
PORT=4000

# BFF API Configuration
API_URL=http://localhost:4000

# Saleor API (used only by BFF, not frontend)
SALEOR_API_URL=https://demo.saleor.io/graphql/
SALEOR_API_TOKEN=

# Mock Mode (set to true to use mock data)
USE_MOCK=true

# Payment Providers
PAYDUNYA_ENABLED=false
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_MODE=test

STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Frontend URLs (for CORS)
FRONTEND_URL=http://localhost:3000
